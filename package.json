{
  "name": "pockethost-root",
  "author": {
    "name": "Ben Allfree",
    "url": "https://github.com/benallfree"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "packages/pockethost/src/mothership-app"
  ],
  "scripts": {
    "lint": "prettier -c \"./**/*.{ts,js,cjs,svelte,json}\"",
    "lint:fix": "prettier -w \"./**/*.{ts,js,cjs,svelte,json}\"",
    "dev:cli": "cd packages/pockethost && bun dev",
    "dev:dashboard": "cd packages/dashboard && bun dev",
    "prod:cli": "cd packages/pockethost && bun start",
    "nofile": "cat /proc/sys/fs/file-nr",
    "mail": "bun ./packages/pockethost/src/cli/index.ts mail"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "prettier": "^3.4.2",
    "prettier-plugin-jsdoc": "^1.3.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-svelte": "^3.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.25.0"
  },
  "patchedDependencies": {
    "@sveltejs/enhanced-img@0.3.8": "patches/@sveltejs__enhanced-img.patch",
    "tail@2.2.6": "patches/tail.patch",
    "@types/tail@2.2.3": "patches/@types__tail.patch"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "cpu-features",
    "dtrace-provider",
    "esbuild",
    "lzma-native",
    "protobufjs",
    "sharp",
    "ssh2",
    "svelte-preprocess",
    "workerd"
  ],
  "packageManager": "bun@1.3.14"
}

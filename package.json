{
  "name": "pockethost-root",
  "author": {
    "name": "Ben Allfree",
    "url": "https://github.com/benallfree"
  },
  "license": "MIT",
  "scripts": {
    "lint": "prettier -c \"./**/*.{ts,js,cjs,svelte,json}\"",
    "lint:fix": "prettier -w \"./**/*.{ts,js,cjs,svelte,json}\"",
    "dev:cli": "cd packages/pockethost && pnpm dev",
    "dev:mothership-hooks": "pnpm --filter pockethost-mothership-app dev",
    "dev:dashboard": "cd packages/dashboard && pnpm dev",
    "check:mothership-hooks": "pnpm --filter pockethost-mothership-app check:fresh",
    "prod:cli": "cd packages/pockethost && pnpm start",
    "nofile": "cat /proc/sys/fs/file-nr",
    "mail": "tsx ./packages/pockethost/src/cli/sendmail.ts"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-jsdoc": "^1.3.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-svelte": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.25.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "tail": "patches/tail.patch",
      "@types/tail": "patches/@types__tail.patch"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "cpu-features",
      "dtrace-provider",
      "esbuild",
      "lzma-native",
      "protobufjs",
      "sharp",
      "ssh2",
      "svelte-preprocess",
      "workerd"
    ]
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}

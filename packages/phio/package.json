    "@s-libs/micro-dash": "^18.0.0",
    "basic-ftp": "^5.0.5",
    "bottleneck": "^2.19.5",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "email-validator": "^2.0.4",
    "env-paths": "^3.0.0",
    "env-var": "^7.5.0",
    "event-stream": "^4.0.1",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.0",
    "lodash": "^4.17.21",
    "multimatch": "^7.0.0",
    "ora": "^8.2.0",
    "pocketbase": "^0.25.1",
    "pretty-bytes": "^5.6.0",
    "pretty-ms": "^7.0.1",
    "ssh2-sftp-client": "^12.1.1",
    "tsx": "^4.19.3",
    "yargs": "^17.7.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "typescript": "^5.7.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }

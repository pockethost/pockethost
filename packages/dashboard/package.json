{
  "name": "@pockethost/dashboard",
  "version": "0.4.2",
  "private": true,
  "main": "./src/app.html",
  "scripts": {
    "check:types": "svelte-check",
    "preview": "npx http-server@latest ./build -P \"http://localhost:8080?\"",
    "dev": "node scripts/sync-route-images.js && vite dev",
    "build": "node scripts/sync-route-images.js && NODE_ENV=production vite build",
    "deploy": "wrangler pages deploy ./build",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "postbuild": "svelte-sitemap --domain https://pockethost.io"
  },
  "type": "module",
  "devDependencies": {
    "@awesome.me/webawesome": "^3.8.0",
    "@beyonk/gdpr-cookie-consent-banner": "^12.1.6",
    "@microsoft/fetch-event-source": "github:pockethost/fetch-event-source#ebe3b7122647b48b93fd11effbbfb915d98956b0",
    "@s-libs/micro-dash": "^18.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.22.2",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/prismjs": "^1.26.5",
    "autoprefixer": "^10.4.21",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "highlight.js": "^11.11.1",
    "mdsvex": "^0.12.6",
    "pockethost": "workspace:^",
    "prismjs": "^1.30.0",
    "sass": "^1.89.2",
    "svelte": "^5.34.9",
    "svelte-check": "^4.2.2",
    "svelte-highlight": "^7.8.3",
    "svelte-preprocess": "^6.0.3",
    "svelte-sitemap": "^2.7.1",
    "tailwindcss": "^3.4.17",
    "unist-util-visit": "^5.0.0",
    "vite": "^6.3.5",
    "wrangler": "^4.25.0"
  }
}
